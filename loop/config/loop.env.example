# Loop runner configuration
# Copy to loop/config/loop.env and customize per project / milestone.

# --- identity ---
# LOOP_PROJECT_NAME="jsonq"

# --- prompt ---
LOOP_PROMPT_FILE="loop/PROMPT.md"
# For planning mode: LOOP_PROMPT_FILE="loop/PROMPT-PLANNING.md"

# --- completion ---
# Informational string the agent may print; NOT used for auto-stop (prose grep false-positives)
LOOP_COMPLETION_SENTINEL="JSONQ-M1-DONE"
# Authoritative stop signal — agent must create this file
LOOP_COMPLETE_MARKER=".loop/COMPLETE"
LOOP_LOG_DIR=".loop/logs"

# --- agent (Claude Code default) ---
LOOP_AGENT_CMD="claude"
LOOP_AGENT_ARGS="--dangerously-skip-permissions"
LOOP_DISALLOWED_TOOLS="Bash(rm:*)"
# LOOP_MODEL="sonnet"

# --- other agents (examples — uncomment and adjust) ---
# LOOP_AGENT_CMD="cursor"
# LOOP_AGENT_ARGS="agent --print --force"
# LOOP_AGENT_USE_STDIN=1

# LOOP_AGENT_CMD="codex"
# LOOP_AGENT_ARGS="exec --full-auto"

# --- limits ---
LOOP_MAX_ITERATIONS=50
LOOP_USAGE_WAIT=1800
LOOP_MAX_USAGE_WAITS=48
LOOP_MAX_TRANSIENT=5

# --- gate (documented for humans; agent runs via PROMPT.md) ---
# GATE_CMD="./loop/scripts/gate.sh"
